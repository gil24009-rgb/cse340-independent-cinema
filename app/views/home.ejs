<%- include("partials/document-head") %>

<main id="main-content">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Now showing</p>
      <h1>Independent films, one focused screen.</h1>
      <p class="hero-summary">
        A small cinema program built around singular films, clear schedules, and time to stay for the conversation.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href="/screenings">View screenings</a>
        <a class="text-link" href="/films">Browse films</a>
      </div>
    </div>

    <aside class="screening-preview" aria-label="Next screening preview">
      <% if (nextScreening) { %>
        <p class="eyebrow">Next screening</p>
        <div class="screening-time">
          <strong><%= nextScreening.timeLabel %></strong>
          <span><%= nextScreening.dateLabel %></span>
        </div>
        <div>
          <h2><a class="title-link" href="/screenings/<%= nextScreening.screening_id %>"><%= nextScreening.film_title %></a></h2>
          <p><%= nextScreening.program_label || "Regular screening" %> · <%= nextScreening.runtime_minutes %> min · <%= nextScreening.availabilityLabel %></p>
        </div>
      <% } else { %>
        <p class="eyebrow">Next screening</p>
        <div class="screening-time">
          <strong>TBA</strong>
          <span>Schedule update</span>
        </div>
        <div>
          <h2>The next schedule is being prepared.</h2>
          <p>Published screening times and availability will appear here.</p>
        </div>
      <% } %>
    </aside>
  </section>

  <section class="schedule-foundation" aria-labelledby="schedule-title">
    <div class="section-heading">
      <div>
        <p class="eyebrow">This week</p>
        <h2 id="schedule-title">A program with room to stay awhile</h2>
      </div>
      <a class="text-link" href="/screenings">Full schedule</a>
    </div>

    <% if (upcomingScreenings.length > 0) { %>
      <ol class="home-screening-list">
        <% upcomingScreenings.forEach((screening) => { %>
          <li>
            <time datetime="<%= new Date(screening.starts_at).toISOString() %>">
              <span><%= screening.dateLabel %></span>
              <strong><%= screening.timeLabel %></strong>
            </time>
            <div>
              <h3><a class="title-link" href="/screenings/<%= screening.screening_id %>"><%= screening.film_title %></a></h3>
              <p><%= screening.program_label || "Regular screening" %> · <%= screening.availabilityLabel %></p>
            </div>
          </li>
        <% }) %>
      </ol>
    <% } else { %>
      <section class="inline-empty-state" aria-labelledby="home-schedule-empty-title">
        <p class="eyebrow">Schedule update</p>
        <h3 id="home-schedule-empty-title">A new screening week has not been published yet.</h3>
        <p>The archive remains available while the next public schedule is prepared.</p>
        <a class="text-link" href="/films">Browse films</a>
      </section>
    <% } %>
  </section>

  <section class="schedule-foundation" aria-labelledby="program-title">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Program</p>
        <h2 id="program-title">Films with a direct path to the schedule</h2>
      </div>
      <a class="text-link" href="/films">Film archive</a>
    </div>

    <% if (programFilms.length > 0) { %>
      <div class="foundation-grid">
        <% programFilms.forEach((film, index) => { %>
          <article>
            <span><%= String(index + 1).padStart(2, "0") %></span>
            <h3><a class="title-link" href="/films/<%= film.slug %>"><%= film.title %></a></h3>
            <p><%= film.director %> · <%= film.runtime_minutes %> min · <%= film.upcoming_screening_count %> upcoming</p>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <section class="inline-empty-state" aria-labelledby="home-films-empty-title">
        <p class="eyebrow">Program update</p>
        <h3 id="home-films-empty-title">The next film program is taking shape.</h3>
        <p>Published films will appear here when the cinema program is ready.</p>
      </section>
    <% } %>
  </section>
</main>

<%- include("partials/document-end") %>
