<%- include("../partials/document-head") %>

<main id="main-content" class="page-content">
  <header class="page-heading detail-heading">
    <p class="eyebrow"><%= screening.program_label || "Screening detail" %></p>
    <h1><%= screening.film_title %></h1>
    <p><%= screening.dateLabel %> · <%= screening.timeRangeLabel %> · <%= screening.priceLabel %></p>
    <p><%= screening.director %> · <%= screening.country %> · <%= screening.release_year %> · <%= screening.runtime_minutes %> min · <%= screening.age_rating %></p>
  </header>

  <section class="detail-grid">
    <div class="detail-copy">
      <h2>Before the screening</h2>
      <p><%= screening.synopsis %></p>
      <div class="detail-actions">
        <% if (currentUser && currentUser.role === "member" && screening.remaining_capacity > 0) { %>
          <form class="inline-action-form" action="/screenings/<%= screening.screening_id %>/bookings" method="post">
            <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
            <button class="button button-primary" type="submit">Book This Screening</button>
          </form>
        <% } else if (!currentUser) { %>
          <a class="button button-primary" href="/login">Sign in to book</a>
        <% } else if (screening.remaining_capacity <= 0) { %>
          <p class="status-note" role="status">This screening is sold out.</p>
        <% } else { %>
          <p class="status-note" role="status">Only Member accounts can book screenings.</p>
        <% } %>
        <a class="text-link" href="/films/<%= screening.film_slug %>">View film detail</a>
        <a class="text-link" href="/screenings">Back to schedule</a>
      </div>
      <% if (bookingError) { %>
        <div class="error-summary" role="alert">
          <p><%= bookingError %></p>
        </div>
      <% } %>
    </div>

    <dl class="detail-list public-detail-list">
      <div>
        <dt>Availability</dt>
        <dd><%= screening.availabilityLabel %></dd>
      </div>
      <div>
        <dt>Capacity</dt>
        <dd><%= screening.capacity %></dd>
      </div>
    </dl>
  </section>
</main>

<%- include("../partials/document-end") %>
