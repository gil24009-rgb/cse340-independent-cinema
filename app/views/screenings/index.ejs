<%- include("../partials/document-head") %>

<main id="main-content" class="page-content">
  <header class="page-heading">
    <p class="eyebrow">Screening schedule</p>
    <h1>Choose the time, then stay for the film.</h1>
    <p>Upcoming screenings are ordered by date with availability visible before booking.</p>
  </header>

  <% if (screenings.length === 0) { %>
    <section class="inline-empty-state" aria-labelledby="screenings-empty-title">
      <p class="eyebrow">Schedule update</p>
      <h2 id="screenings-empty-title">The next screening schedule is almost ready.</h2>
      <p>Published dates and availability will appear here.</p>
      <a class="text-link" href="/films">Browse the film archive</a>
    </section>
  <% } else { %>
    <section class="schedule-insight-panel" aria-labelledby="schedule-insight-title">
      <div>
        <p class="eyebrow">At a glance</p>
        <h2 id="schedule-insight-title">Pick by time, film, or remaining seats.</h2>
        <p>Independent cinema visitors usually compare the film, start time, finish time, and seat availability before choosing a screening.</p>
      </div>
      <dl class="schedule-insight-grid">
        <div>
          <dt>Next</dt>
          <dd><%= scheduleSummary.nextScreeningLabel %></dd>
        </div>
        <div>
          <dt>Program</dt>
          <dd><%= scheduleSummary.filmCount %> films</dd>
        </div>
        <div>
          <dt>Showtimes</dt>
          <dd><%= scheduleSummary.screeningCount %> screenings</dd>
        </div>
        <div>
          <dt>Availability</dt>
          <dd><%= scheduleSummary.totalRemainingSeats %> seats open</dd>
        </div>
      </dl>
    </section>

    <ol class="screening-list">
      <% screenings.forEach((screening) => { %>
        <li class="screening-row">
          <time datetime="<%= new Date(screening.starts_at).toISOString() %>" class="screening-date">
            <span><%= screening.dateLabel %></span>
            <strong><%= screening.timeLabel %></strong>
            <span>Ends <%= screening.endTimeLabel %></span>
          </time>
          <div class="screening-film">
            <p class="eyebrow"><%= screening.program_label || "Regular screening" %></p>
            <h2><a class="title-link" href="/films/<%= screening.film_slug %>"><%= screening.film_title %></a></h2>
            <p><%= screening.director %> · <%= screening.runtime_minutes %> min · <%= screening.age_rating %></p>
            <p class="screening-utility-line"><%= screening.timeRangeLabel %> · <%= screening.priceLabel %></p>
          </div>
          <div class="screening-availability">
            <% if (screening.has_guest_talk) { %>
              <span class="status-badge">Guest talk</span>
            <% } %>
            <strong><%= screening.availabilityLabel %></strong>
            <span><%= screening.seatCountLabel %></span>
            <a class="button button-secondary" href="/screenings/<%= screening.screening_id %>">Choose Screening</a>
          </div>
        </li>
      <% }) %>
    </ol>
  <% } %>
</main>

<%- include("../partials/document-end") %>
