<%- include("../partials/document-head") %>

<main id="main-content" class="page-content staff-dashboard">
  <section class="page-heading">
    <p class="eyebrow">Staff operations</p>
    <h1>Welcome, <%= staffName %>.</h1>
    <p>Check in Members, moderate public reviews, and keep contact messages moving from the same operational desk.</p>
  </section>

  <nav class="staff-overview" aria-label="Staff operations overview">
    <% staffDashboardSummary.forEach((item) => { %>
      <a class="staff-overview-card" href="<%= item.href %>">
        <span class="eyebrow"><%= item.label %></span>
        <strong><%= item.value %></strong>
        <span><%= item.detail %></span>
      </a>
    <% }) %>
  </nav>

  <section class="page-section" aria-labelledby="staff-bookings-heading">
    <div class="section-heading section-heading-stack">
      <div>
        <p class="eyebrow">Booking workflow</p>
        <h2 id="staff-bookings-heading">Operational bookings</h2>
      </div>
    </div>

    <% if (screeningGroups.length > 0) { %>
      <div class="staff-screening-roster" aria-label="Operational booking roster grouped by screening">
        <% screeningGroups.forEach((screeningGroup) => { %>
          <article class="staff-screening-group" aria-labelledby="staff-screening-<%= screeningGroup.screeningId %>">
            <header class="staff-screening-summary">
              <div>
                <p class="eyebrow"><%= screeningGroup.programLabel %></p>
                <h3 id="staff-screening-<%= screeningGroup.screeningId %>"><%= screeningGroup.filmTitle %></h3>
                <p><%= screeningGroup.screeningDisplay %></p>
              </div>
              <div class="staff-screening-counts" aria-label="Screening work summary">
                <span><%= screeningGroup.actionSummary %></span>
                <span><%= screeningGroup.bookingSummary %></span>
                <% if (screeningGroup.screeningStatusDisplay) { %>
                  <span><%= screeningGroup.screeningStatusDisplay %></span>
                <% } %>
              </div>
            </header>
            <div class="status-table staff-booking-table" role="table" aria-label="Operational booking status for <%= screeningGroup.filmTitle %>">
              <div class="status-row status-header staff-booking-row" role="row">
                <span role="columnheader">Booking</span>
                <span role="columnheader">Member</span>
                <span role="columnheader">Status</span>
                <span role="columnheader">Actions</span>
              </div>
              <% screeningGroup.bookings.forEach((booking) => { %>
                <div class="status-row staff-booking-row" role="row">
                  <div role="cell">
                    <span class="status-cell-label">Booking</span>
                    <h4>Booking #<%= booking.booking_id %></h4>
                    <p class="owner-row-note">Booked <%= booking.bookedAtDisplay %></p>
                  </div>
                  <div role="cell">
                    <span class="status-cell-label">Member</span>
                    <strong><%= booking.memberDisplay %></strong>
                    <p class="owner-row-note"><%= booking.member_email %></p>
                  </div>
                  <div role="cell">
                    <span class="status-cell-label">Status</span>
                    <span class="status-badge"><%= booking.statusDisplay %></span>
                    <% if (booking.cancelledAtDisplay) { %>
                      <p class="owner-row-note">Cancelled <%= booking.cancelledAtDisplay %></p>
                    <% } %>
                  </div>
                  <div class="owner-actions" role="cell">
                    <span class="status-cell-label">Actions</span>
                    <% if (booking.transitions.length > 0) { %>
                      <% booking.transitions.forEach(([toStatus, label]) => { %>
                        <form action="/staff/bookings/<%= booking.booking_id %>/status" method="post">
                          <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
                          <input type="hidden" name="toStatus" value="<%= toStatus %>" />
                          <button class="button button-secondary" type="submit"><%= label %></button>
                        </form>
                      <% }) %>
                    <% } else { %>
                      <p class="status-note">No staff action available.</p>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            </div>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="inline-empty-state">
        <p class="eyebrow">No operational bookings</p>
        <h3>No bookings need staff action.</h3>
        <p>Confirmed and checked-in bookings will appear here when there is work for the front desk.</p>
      </div>
    <% } %>
  </section>

  <section class="page-section" aria-labelledby="staff-reviews-heading">
    <div class="section-heading section-heading-stack">
      <div>
        <p class="eyebrow">Review moderation</p>
        <h2 id="staff-reviews-heading">Member reviews</h2>
      </div>
    </div>

    <% if (reviews.length > 0) { %>
      <div class="status-table staff-review-table" role="table" aria-label="Review moderation queue">
        <div class="status-row status-header staff-review-row" role="row">
          <span role="columnheader">Review</span>
          <span role="columnheader">Member</span>
          <span role="columnheader">Visibility</span>
          <span role="columnheader">Actions</span>
        </div>
        <% reviews.forEach((review) => { %>
          <div class="status-row staff-review-row" role="row">
            <div role="cell">
              <span class="status-cell-label">Review</span>
              <h3><%= review.film_title %></h3>
              <p class="owner-row-note"><%= review.ratingDisplay %> · Updated <%= review.updatedAtDisplay %></p>
              <p><%= review.body %></p>
            </div>
            <div role="cell">
              <span class="status-cell-label">Member</span>
              <strong><%= review.memberDisplay %></strong>
              <p class="owner-row-note"><%= review.member_email %></p>
            </div>
            <div role="cell">
              <span class="status-cell-label">Visibility</span>
              <span class="status-badge"><%= review.visibilityDisplay %></span>
              <% if (review.moderation_note) { %>
                <p class="owner-row-note"><%= review.moderation_note %></p>
              <% } %>
              <% if (review.moderatorDisplay) { %>
                <p class="owner-row-note">Last moderated by <%= review.moderatorDisplay %></p>
              <% } %>
            </div>
            <div class="owner-actions" role="cell">
              <span class="status-cell-label">Actions</span>
              <form class="staff-note-action" action="/staff/reviews/<%= review.review_id %>/visibility" method="post">
                <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
                <input type="hidden" name="isVisible" value="<%= review.visibilityValue %>" />
                <label class="visually-hidden" for="review-note-<%= review.review_id %>">Moderation note for review <%= review.review_id %></label>
                <input id="review-note-<%= review.review_id %>" name="moderationNote" type="text" maxlength="500" placeholder="Optional note" />
                <button class="button button-secondary" type="submit"><%= review.visibilityActionLabel %></button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="inline-empty-state">
        <p class="eyebrow">No reviews</p>
        <h3>No Member reviews are waiting in the moderation queue.</h3>
        <p>Reviews will appear here after Members complete bookings and publish feedback.</p>
      </div>
    <% } %>
  </section>

  <section class="page-section" aria-labelledby="staff-messages-heading">
    <div class="section-heading section-heading-stack">
      <div>
        <p class="eyebrow">Contact messages</p>
        <h2 id="staff-messages-heading">Message queue</h2>
      </div>
    </div>

    <% if (contactMessages.length > 0) { %>
      <div class="status-table staff-message-table" role="table" aria-label="Contact message queue">
        <div class="status-row status-header staff-message-row" role="row">
          <span role="columnheader">Message</span>
          <span role="columnheader">Sender</span>
          <span role="columnheader">Status</span>
          <span role="columnheader">Actions</span>
        </div>
        <% contactMessages.forEach((message) => { %>
          <div class="status-row staff-message-row" role="row">
            <div role="cell">
              <span class="status-cell-label">Message</span>
              <h3><%= message.subject %></h3>
              <p class="owner-row-note">Received <%= message.createdAtDisplay %></p>
              <p><%= message.body %></p>
            </div>
            <div role="cell">
              <span class="status-cell-label">Sender</span>
              <strong><%= message.name %></strong>
              <p class="owner-row-note"><%= message.email %></p>
              <% if (message.requester_email) { %>
                <p class="owner-row-note">Signed-in account: <%= message.requester_email %></p>
              <% } %>
            </div>
            <div role="cell">
              <span class="status-cell-label">Status</span>
              <span class="status-badge"><%= message.statusDisplay %></span>
              <p class="owner-row-note">Assigned to <%= message.assigneeDisplay %></p>
              <% if (message.staff_note) { %>
                <p class="owner-row-note"><%= message.staff_note %></p>
              <% } %>
            </div>
            <div class="owner-actions" role="cell">
              <span class="status-cell-label">Actions</span>
              <% message.actions.forEach(([status, label]) => { %>
                <form class="staff-note-action" action="/staff/messages/<%= message.message_id %>/status" method="post">
                  <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
                  <input type="hidden" name="status" value="<%= status %>" />
                  <label class="visually-hidden" for="message-note-<%= message.message_id %>-<%= status %>">Staff note for message <%= message.message_id %></label>
                  <input id="message-note-<%= message.message_id %>-<%= status %>" name="staffNote" type="text" placeholder="Optional note" />
                  <button class="button button-secondary" type="submit"><%= label %></button>
                </form>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="inline-empty-state">
        <p class="eyebrow">No messages</p>
        <h3>No contact messages need staff processing.</h3>
        <p>Public contact submissions will appear here with new, in progress, and closed states.</p>
      </div>
    <% } %>
  </section>
</main>

<%- include("../partials/document-end") %>
