<%- include("../partials/document-head") %>

<main id="main-content" class="page-content member-dashboard">
  <section class="page-heading">
    <p class="eyebrow">Member account</p>
    <h1>Welcome, <%= memberName %>.</h1>
    <p>Track your bookings, screening times, and current booking status from one place.</p>
  </section>

  <nav class="account-overview" aria-label="Member account overview">
    <% memberAccountSummary.forEach((item) => { %>
      <a class="account-overview-card" href="<%= item.href %>">
        <span class="eyebrow"><%= item.label %></span>
        <strong><%= item.value %></strong>
        <span><%= item.detail %></span>
      </a>
    <% }) %>
  </nav>

  <section class="page-section" aria-labelledby="member-bookings-heading">
    <div class="section-heading section-heading-stack">
      <div>
        <p class="eyebrow">My bookings</p>
        <h2 id="member-bookings-heading">Booking history</h2>
      </div>
      <a class="text-link" href="/screenings">Browse screenings</a>
    </div>

    <% if (bookings.length > 0) { %>
      <ol class="booking-list" aria-label="Your booking history">
        <% bookings.forEach((booking) => { %>
          <li class="booking-card">
            <div>
              <p class="eyebrow"><%= booking.timing %></p>
              <h3><a class="title-link" href="/account/bookings/<%= booking.booking_id %>"><%= booking.film_title %></a></h3>
              <dl class="compact-detail-list">
                <div>
                  <dt>Status</dt>
                  <dd><span class="status-badge"><%= booking.statusDisplay %></span></dd>
                </div>
                <div>
                  <dt>Screening</dt>
                  <dd><%= booking.startsAtDisplay %></dd>
                </div>
                <div>
                  <dt>Booked</dt>
                  <dd><%= booking.bookedAtDisplay %></dd>
                </div>
                <% if (booking.cancelledAtDisplay) { %>
                  <div>
                    <dt>Cancelled</dt>
                    <dd><%= booking.cancelledAtDisplay %></dd>
                  </div>
                <% } %>
              </dl>
            </div>
            <a class="button button-secondary" href="/account/bookings/<%= booking.booking_id %>">View Details</a>
          </li>
        <% }) %>
      </ol>
    <% } else { %>
      <div class="inline-empty-state">
        <p class="eyebrow">No bookings yet</p>
        <h3>Your booking history is empty.</h3>
        <p>Choose an upcoming screening to create your first Member booking. Your status and screening history will appear here after booking.</p>
        <a class="button button-primary" href="/screenings">Browse screenings</a>
      </div>
    <% } %>
  </section>

  <section class="page-section" aria-labelledby="member-reviews-heading">
    <div class="section-heading section-heading-stack">
      <div>
        <p class="eyebrow">My reviews</p>
        <h2 id="member-reviews-heading">Film reviews</h2>
      </div>
      <a class="text-link" href="/account/reviews/new">Write a review</a>
    </div>

    <% const availableReviewFilms = reviewableFilms.filter((film) => !film.hasReview); %>
    <% if (availableReviewFilms.length > 0) { %>
      <div class="review-prompt">
        <p class="eyebrow">Ready to review</p>
        <h3>Completed screenings can now become reviews.</h3>
        <p>
          <% availableReviewFilms.forEach((film, index) => { %>
            <%= film.film_title %><%= index < availableReviewFilms.length - 1 ? ", " : "" %>
          <% }) %>
        </p>
        <a class="button button-primary" href="/account/reviews/new">Write a Review</a>
      </div>
    <% } else { %>
      <p class="status-note">Completed bookings without a review will appear here.</p>
    <% } %>

    <% if (reviews.length > 0) { %>
      <ol class="review-list" aria-label="Your film reviews">
        <% reviews.forEach((review) => { %>
          <li class="review-card">
            <div>
              <p class="eyebrow"><%= review.visibilityDisplay %></p>
              <h3><a class="title-link" href="/account/reviews/<%= review.review_id %>"><%= review.film_title %></a></h3>
              <dl class="compact-detail-list">
                <div>
                  <dt>Rating</dt>
                  <dd><%= review.ratingDisplay %></dd>
                </div>
                <div>
                  <dt>Updated</dt>
                  <dd><%= review.updatedAtDisplay %></dd>
                </div>
              </dl>
              <p><%= review.body %></p>
            </div>
            <div class="detail-actions">
              <a class="button button-secondary" href="/account/reviews/<%= review.review_id %>">View Review</a>
              <a class="button button-secondary" href="/account/reviews/<%= review.review_id %>/edit">Edit Review</a>
            </div>
          </li>
        <% }) %>
      </ol>
    <% } else { %>
      <div class="inline-empty-state">
        <p class="eyebrow">No reviews yet</p>
        <h3>Your review list is empty.</h3>
        <p>After a booking reaches completed status, you can write one review for that film.</p>
      </div>
    <% } %>
  </section>
</main>

<%- include("../partials/document-end") %>
