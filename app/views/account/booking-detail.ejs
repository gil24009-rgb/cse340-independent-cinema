<%- include("../partials/document-head") %>

<main id="main-content" class="empty-state">
  <p class="eyebrow">Member booking</p>
  <h1><%= booking.film_title %></h1>
  <p>Your booking detail is available only to the signed-in Member who owns it.</p>

  <dl class="detail-list">
    <div>
      <dt>Status</dt>
      <dd><%= booking.statusDisplay %></dd>
    </div>
    <div>
      <dt>Screening time</dt>
      <dd><%= booking.startsAtDisplay %></dd>
    </div>
    <div>
      <dt>Booked at</dt>
      <dd><%= booking.bookedAtDisplay %></dd>
    </div>
    <% if (booking.cancelledAtDisplay) { %>
      <div>
        <dt>Cancelled at</dt>
        <dd><%= booking.cancelledAtDisplay %></dd>
      </div>
    <% } %>
    <div>
      <dt>Booking ID</dt>
      <dd><%= booking.booking_id %></dd>
    </div>
  </dl>

  <div class="detail-actions">
    <a class="button button-primary" href="/account">Return to account</a>
    <% if (booking.canCancel) { %>
      <form class="inline-action-form" action="/account/bookings/<%= booking.booking_id %>/cancel" method="post">
        <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
        <button class="button button-secondary" type="submit">Cancel Booking</button>
      </form>
    <% } else if (booking.status === "cancelled") { %>
      <p class="status-note">This booking has already been cancelled.</p>
    <% } else { %>
      <p class="status-note">This booking is no longer eligible for Member cancellation.</p>
    <% } %>
  </div>
</main>

<%- include("../partials/document-end") %>
