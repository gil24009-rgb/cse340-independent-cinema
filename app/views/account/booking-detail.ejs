<%- include("../partials/document-head") %>

<main id="main-content" class="empty-state">
  <p class="eyebrow">Member booking</p>
  <h1><%= booking.film_title %></h1>
  <p>Your booking detail is available only to the signed-in Member who owns it.</p>

  <dl class="detail-list">
    <div>
      <dt>Status</dt>
      <dd><%= booking.statusDisplay %></dd>
    </div>
    <div>
      <dt>Screening time</dt>
      <dd><%= booking.startsAtDisplay %></dd>
    </div>
    <div>
      <dt>Booked at</dt>
      <dd><%= booking.bookedAtDisplay %></dd>
    </div>
    <% if (booking.cancelledAtDisplay) { %>
      <div>
        <dt>Cancelled at</dt>
        <dd><%= booking.cancelledAtDisplay %></dd>
      </div>
    <% } %>
    <div>
      <dt>Booking ID</dt>
      <dd><%= booking.booking_id %></dd>
    </div>
  </dl>

  <section class="status-timeline-section" aria-labelledby="booking-status-history-heading">
    <p class="eyebrow">Status history</p>
    <h2 id="booking-status-history-heading">Booking timeline</h2>
    <% if (statusHistory.length > 0) { %>
      <ol class="status-timeline" aria-label="Booking status history">
        <% statusHistory.forEach((entry) => { %>
          <li class="status-timeline-item">
            <div class="status-timeline-marker" aria-hidden="true"></div>
            <div>
              <p class="status-timeline-title">
                <span><%= entry.fromStatusDisplay %></span>
                <span>to</span>
                <span><%= entry.toStatusDisplay %></span>
              </p>
              <dl class="status-timeline-meta">
                <div>
                  <dt>Changed</dt>
                  <dd><%= entry.changedAtDisplay %></dd>
                </div>
                <div>
                  <dt>By</dt>
                  <dd><%= entry.changedByDisplay %></dd>
                </div>
              </dl>
              <% if (entry.note) { %>
                <p class="status-timeline-note"><%= entry.note %></p>
              <% } %>
            </div>
          </li>
        <% }) %>
      </ol>
    <% } else { %>
      <p class="status-note">No status history is recorded for this booking yet.</p>
    <% } %>
  </section>

  <div class="detail-actions">
    <a class="button button-primary" href="/account">Return to account</a>
    <% if (booking.canCancel) { %>
      <form class="inline-action-form" action="/account/bookings/<%= booking.booking_id %>/cancel" method="post">
        <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
        <button class="button button-secondary" type="submit">Cancel Booking</button>
      </form>
    <% } else if (booking.status === "cancelled") { %>
      <p class="status-note">This booking has already been cancelled.</p>
    <% } else { %>
      <p class="status-note">This booking is no longer eligible for Member cancellation.</p>
    <% } %>
  </div>
</main>

<%- include("../partials/document-end") %>
